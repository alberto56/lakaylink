{#
/**
 * @file
 * Electro Commerce paragraph template for product offer banner.
 *
 * Paragraph type: product_offer_banner
 * Fields:
 *   - field_offer_eyebrow: Text (e.g. "Find The Best Camera for You!")
 *   - field_offer_title: Text (e.g. "Smart Camera")
 *   - field_offer_discount: Text (e.g. "40%")
 *   - field_offer_image: Image
 *   - field_offer_url: Link
 */
#}

{% set offer_url = paragraph.field_offer_url.0.url|default('#') %}
{% set offer_eyebrow = paragraph.field_offer_eyebrow.value %}
{% set offer_title = paragraph.field_offer_title.value %}
{% set offer_discount = paragraph.field_offer_discount.value %}

<a href="{{ offer_url }}"
   class="d-flex align-items-center justify-content-between border bg-white rounded p-4">
  <div>
    {% if offer_eyebrow %}
      <p class="text-muted mb-3">{{ offer_eyebrow }}</p>
    {% endif %}
    {% if offer_title %}
      <h3 class="text-primary">{{ offer_title }}</h3>
    {% endif %}
    {% if offer_discount %}
      <h1 class="display-3 text-secondary mb-0">
        {{ offer_discount }} <span class="text-primary fw-normal">{{ 'Off'|t }}</span>
      </h1>
    {% endif %}
  </div>
  {% if content.field_offer_image %}
    <div class="offer-image">{{ content.field_offer_image }}</div>
  {% endif %}
</a>
