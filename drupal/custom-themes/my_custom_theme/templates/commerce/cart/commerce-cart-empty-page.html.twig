{#
/**
 * @file
 * Theme override for an empty Commerce cart page.
 */
#}

<div class="container-fluid py-5">
    <div class="container py-5">

        <div class="row justify-content-center">
            <div class="col-lg-8">

                <div class="bg-light rounded p-5 text-center shadow-sm">

                    <i class="fa fa-shopping-cart fa-4x text-primary mb-4"></i>

                    <h2 class="mb-3">
                        {{ "Your shopping cart is empty"|t  }}
                    </h2>

                    <p class="text-muted mb-4">
                        {{ "Looks like you haven't added any products to your cart yet."|t }}
                    </p>

                    <a href="{{ path('<front>') }}"
                       class="btn btn-primary rounded-pill px-5 py-3">
                        {{ "Continue Shopping"|t }}
                    </a>

                </div>

            </div>
        </div>

    </div>
</div>