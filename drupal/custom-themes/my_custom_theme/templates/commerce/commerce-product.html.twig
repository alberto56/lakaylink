{#
/**
 * @file
 *
 * Default product template.
 *
 * Available variables:
 * - attributes: HTML attributes for the wrapper.
 * - product: The rendered product fields.
 *   Use 'product' to print them all, or print a subset such as
 *   'product.title'. Use the following code to exclude the
 *   printing of a given field:
 *   @code
 *   {{ product|without('title') }}
 *   @endcode
 * - product_entity: The product entity.
 * - product_url: The product URL.
 * - title_prefix: Additional output populated by modules, intended to be
 *   displayed in front of the main title tag that appears in the template.
 * - title_suffix: Additional output populated by modules, intended to be
 *   displayed after the main title tag that appears in the template.
 *
 * @ingroup themeable
 */
#}
{% set user_roles = user.getRoles() %}

{% if 'buyer' not in user_roles %}
  <div class="alert alert-warning mt-3" role="alert">
    <strong>Notice:</strong> Only users with the Buyer role can view add to cart button.
  </div>
{% endif %}

<article{{ attributes }}>

  {{ title_prefix }}
  {{ title_suffix }}

  <div class="container py-5">

    <div class="row">

      {# ================= LEFT: IMAGE ================= #}
      <div class="col-lg-6 mb-4">

        {% if product.variation_field_image %}
          {{ product.variation_field_image }}
        {% else %}
          <div class="text-muted">No image available</div>
        {% endif %}

      </div>

      {# ================= RIGHT: INFO ================= #}
      <div class="col-lg-6">

        {# Title #}
        <h3 class="fw-bold mb-2">
          {{ product.variation_title }}
        </h3>

        {# Brand / store #}
        {% if product.field_brand %}
          <div class="mb-2">
            {{ product.field_brand }}
          </div>
        {% endif %}

        {# Category #}
        {% if product.field_category %}
          <p class="text-muted mb-1">{{ product.field_category }}</p>
        {% endif %}

        {% if product.field_sub_category %}
          <p class="text-muted mb-3">{{ product.field_sub_category }}</p>
        {% endif %}

        {# Price (variation-based) #}
        <h4 class="text-primary mb-3">
          {{ product.variation_price }}
        </h4>

        {# ================= STOCK INFO ================= #}
        <div class="small text-muted mb-3">
          <div>{{ product.variation_field_stock }}</div>
          <div>{{ product.variation_field_inventory_status }}</div>
        </div>

        {# ================= ADD TO CART ================= #}
        <div class="add-to-cart mb-4">
          {# This is the correct Commerce form #}
          {{ product.variations }}
        </div>

        {% if product_entity.variations %}
          <div class="product-variations mb-4">
            <h6>Select Option</h6>

            <div class="d-flex flex-wrap gap-2">
              {% for variation in product_entity.variations %}
                <a href="{{ path('entity.commerce_product.canonical', {
                  commerce_product: product_entity.id
                }) }}?v={{ variation.entity.id }}"
                  class="btn btn-outline-primary">
                  {{ variation.entity.title.value }}
                </a>
              {% endfor %}
            </div>
          </div>
        {% endif %}

      </div>

    </div>

    {# ================= TABS ================= #}
    <div class="mt-5">

      <ul class="nav nav-tabs">

        <li class="nav-item">
          <button class="nav-link active"
                  data-bs-toggle="tab"
                  data-bs-target="#description">
            Description
          </button>
        </li>
      </ul>

      <div class="tab-content border p-4">

        <div class="tab-pane fade show active" id="description">
          {{ product.body }}
        </div>

        <div class="tab-pane fade" id="reviews">
          {{ product.product_reviews }}
        </div>

      </div>

    </div>

  </div>

</article>